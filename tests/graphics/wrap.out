{"frame":1,"mouse":[_,_],"down":false,"draws":[{"op":"text","layer":0,"x":18,"y":21,"size":19,"color":"edeae4","text":"The quick brown fox jumps over the"},{"op":"text","layer":0,"x":18,"y":46,"size":19,"color":"edeae4","text":"lazy dog and then keeps running"},{"op":"text","layer":0,"x":18,"y":71,"size":19,"color":"edeae4","text":"well past the edge of the column,"},{"op":"text","layer":0,"x":18,"y":96,"size":19,"color":"edeae4","text":"so the greedy word wrap must"},{"op":"text","layer":0,"x":18,"y":121,"size":19,"color":"edeae4","text":"break it into several tidy lines."}]}
